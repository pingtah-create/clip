# Copy this file to .env and fill in your key.

# --- LLM (clip-picking) ---
# Default: real Anthropic Claude.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Alternative: DeepSeek V4 via its Anthropic-compatible endpoint ---
# Uncomment these THREE lines (and comment out the two above) to switch to DeepSeek
# without changing any code. DeepSeek implements the Anthropic API, so the same SDK works.
#
# ANTHROPIC_API_KEY=sk-...            # your DeepSeek API key, not an Anthropic one
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# CLAUDE_MODEL=deepseek-v4-pro        # or deepseek-v4-flash for cheaper/faster

# --- Whisper transcription ---
WHISPER_MODEL=small          # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu           # cpu (default, works anywhere) | cuda (NVIDIA GPU + CUDA installed)
WHISPER_COMPUTE=int8         # int8 for CPU, float16 for GPU

# --- YouTube auto-upload ---
# Off by default. To enable: put client_secret.json in the project root (Desktop OAuth from
# Google Cloud Console), then run `python -m backend.youtube` once to authorize in a browser.
# Each upload costs 1,600 of YouTube's 10,000/day free quota — so ~6 uploads/day max.
YOUTUBE_AUTO_UPLOAD=false    # true to enable autonomous uploads at end of pipeline
YOUTUBE_MIN_SCORE=85         # Claude's score (1-100) below this won't upload
YOUTUBE_PRIVACY=private      # private | unlisted | public — start with private until you trust the threshold
YOUTUBE_DEFAULT_TAGS=shorts,investing

# --- Daemon (autonomous channel polling) ---
# List channel URLs in channels.txt, then run `run_daemon.bat`. The daemon polls
# every DAEMON_INTERVAL_HOURS, processes new uploads via the pipeline, and posts
# the clips that score >= DAEMON_MIN_SCORE_TO_UPLOAD. On a fresh data/processed.json
# the first cycle seeds "already-seen" markers without processing, so the daemon
# never backfills a busy channel.
# Tuned for YouTube free tier (10k quota/day = 6 uploads/day max).
# Lower DAEMON_N_CLIPS_PER_VIDEO and raise DAEMON_MIN_SCORE_TO_UPLOAD so the
# daily quota goes to your strongest clips, not filler.
DAEMON_INTERVAL_HOURS=4
DAEMON_N_CLIPS_PER_VIDEO=2
DAEMON_MIN_SCORE_TO_UPLOAD=85
DAEMON_MAX_VIDEO_DURATION_MIN=360   # accept long podcasts up to 6h (transcription is slow but fine)
DAEMON_MIN_VIDEO_DURATION_MIN=20    # 20+ min biases toward podcasts/interviews (best clip source)
DAEMON_PODCAST_BIAS=true            # append "podcast interview" to queries + sort results by views
DAEMON_MAX_UPLOADS_PER_DAY=2        # don't flood a young channel; concentrate test-traffic on the best
DAEMON_CTA=Follow for daily clips from the world's top investors.

# Reframe: how far to pull back the 9:16 crop. 1.0 = tight (face fills frame, very
# zoomed). 1.4 = pulled back ~40% (shows shoulders/context). Higher = more zoomed out.
REFRAME_ZOOM_OUT=1.4
# Reject clips where a speaker is on screen less than this fraction of the time.
MIN_FACE_COVERAGE=0.5
# Verify each rendered clip (captions present, not black, has audio) before it can
# upload — the create/verify split. false to disable.
VERIFY_CLIPS=true
DAEMON_DURATION_PRESET=standard
DAEMON_MAX_VIDEO_AGE_DAYS=14
DAEMON_RESULTS_PER_QUERY=1
DAEMON_PIPELINE_TIMEOUT_MIN=180     # raised to 3h: a 6h podcast on CPU whisper needs the headroom
DAEMON_KEEP_INTERMEDIATES=false     # true keeps per-job source/audio files (debugging; fills disk)
